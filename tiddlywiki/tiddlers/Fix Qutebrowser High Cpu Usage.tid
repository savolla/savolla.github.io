``` {.bash org-language="sh"}
qutebrowser \\
    --qt-flag ignore-gpu-blacklist \\
    --QT-flag enable-gpu-rasterization \\
    --qt-flag enable-native-gpu-memory-buffers \\
    --qt-flag num-raster-threads=4
```
