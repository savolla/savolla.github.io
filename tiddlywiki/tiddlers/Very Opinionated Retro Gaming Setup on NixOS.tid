downloading metadata

``` bash
#!/usr/bin/env bash

SYSTEMS=(snes nes megadrive gba gb gbc nds n64 psx ps2)

for system in "${SYSTEMS[@]}"; do
  echo "=== Scraping $system ==="
  Skyscraper -p "$system" -s screenscraper --flags unpack
  Skyscraper -p "$system"
done

echo "All done. Open Pegasus and reload game lists."
```
