## Nix Shell for Building DWM on NixOS

``` nix
{
  pkgs ? import <nixpkgs> { },
}:

pkgs.mkShell {
  name = "dwm-build-shell";

  buildInputs = [
    pkgs.gcc # C compiler
    pkgs.gnumake # Make tool
    pkgs.libX11 # X11 library
    pkgs.libXinerama # Optional: for multi-monitor support
    pkgs.libXft # Optional: font rendering
    pkgs.pkg-config # For compile-time library detection
  ];

  # Environment variables to make building easier
  shellHook = ''
    echo "Welcome to the DWM build shell!"
    echo "Use 'make clean install' inside the dwm source directory."
  '';
}
```

## DWM with Animations

picom has added animations support just like in hyprland. we simply install the official `picom` package and not any fork.

put the following into your `~/.config/picom.conf`

``` conf
backend = "glx";
vsync = true;
corner-radius = 10;
no-use-damage = true;
xrender-sync-fence = true;

rounded-corners-exclude = [
  "window_type = 'dock'",
  "window_type = 'desktop'",
  "fullscreen"
];

rules = (
  {
    match = "window_type = 'dock' || window_type = 'desktop' || fullscreen";
    corner-radius = 0;
  },
  {
    animations = (
      {
        triggers = ["open", "show"];
        d = 0.4;
        scale-x = { duration = "d"; start = 0.9; end = 1; curve = "cubic-bezier(.63,0,.32,1.6)"; };
        scale-y = { duration = "d"; start = 0.9; end = 1; curve = "cubic-bezier(.63,0,.32,1.6)"; };
        offset-x = { duration = "d"; start = "window-width * 0.05"; end = 0; curve = "cubic-bezier(.63,0,.32,1.6)"; };
        offset-y = { duration = "d"; start = "window-height * 0.05"; end = 0; curve = "cubic-bezier(.63,0,.32,1.6)"; };
        opacity = { duration = "d"; start = 0; end = 1; curve = "cubic-bezier(.63,0,.32,1.6)"; };
      },
      {
        triggers = ["close", "hide"];
        d = 0.4;
        scale-x = { duration = "d"; start = 1; end = 0.9; curve = "cubic-bezier(0.85,0,0.15,1)"; };
        scale-y = { duration = "d"; start = 1; end = 0.9; curve = "cubic-bezier(0.85,0,0.15,1)"; };
        offset-x = { duration = "d"; end = "window-width * 0.05"; start = 0; curve = "cubic-bezier(0.85,0,0.15,1)"; };
        offset-y = { duration = "d"; end = "window-height * 0.05"; start = 0; curve = "cubic-bezier(0.85,0,0.15,1)"; };
        opacity = { duration = "d"; start = 1; end = 0; curve = "cubic-bezier(0.85,0,0.15,1)"; };
      },
      {
        triggers = ["geometry"];
        d = 0.4;
        saved-image-blend = 0;
        scale-x = { duration = "d"; start = "window-width-before / window-width"; end = 1; curve = "cubic-bezier(0.85,0,0.15,1)"; };
        scale-y = { duration = "d"; start = "window-height-before / window-height"; end = 1; curve = "cubic-bezier(0.85,0,0.15,1)"; };
        offset-x = { duration = "d"; start = "window-x-before - window-x"; end = 0; curve = "cubic-bezier(0.85,0,0.15,1)"; };
        offset-y = { duration = "d"; start = "window-y-before - window-y"; end = 0; curve = "cubic-bezier(0.85,0,0.15,1)"; };
      },
    );
  },
);

fading = true;
fade-in-step = 0.03;
fade-out-step = 0.03;
shadow = true;
shadow-radius = 15;
shadow-offset-x = -15;
shadow-offset-y = -15;
```

### False

we\'ll use different fork of `picom` that is `icom-ftlabs` add this in your `let` block in `configuration.nix`

``` nix
 picomFtlabs = pkgs.picom.overrideAttrs (oldAttrs: {
   version = "11";
   src = pkgs.fetchFromGitHub {
     owner = "FT-Labs";
     repo = "picom";
     rev = "next";
      hash = "sha256-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=";
   };
   mesonFlags = [ "-Dwith_docs=false" ];
   doInstallCheck = false;
 });
in
```

Add it to your syste packages

``` nix
environment.systemPackages = [ picomFtlabs ];
```

add this into your services

``` nix
services.picom = {
  enable = true;
  package = picomFtlabs;
};
```

